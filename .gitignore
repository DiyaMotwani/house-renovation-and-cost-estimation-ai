# Python
__pycache__/
*.py[cod]
venv/
.env

# Storage (uploaded/generated files)
backend/storage/uploads/*
backend/storage/generated/*
backend/storage/reports/*
!backend/storage/**/.gitkeep

# Node
node_modules/
frontend/dist/
frontend/.env

# IDE
.idea/
.vscode/
*.swp

# NOTE: alembic migration files MUST be committed — do not ignore them.
# (Only the autogenerated __pycache__ inside is ignored, via the global rule above.)